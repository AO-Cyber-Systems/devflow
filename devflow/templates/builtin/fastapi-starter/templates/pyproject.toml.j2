[build-system]
requires = ["setuptools>=61.0"]
build-backend = "setuptools.build_meta"

[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "FastAPI application"
requires-python = ">={{ python_version }}"
dependencies = [
    "fastapi>=0.109.0",
    "uvicorn[standard]>=0.27.0",
    "pydantic>=2.5.0",
    "pydantic-settings>=2.1.0",{% if database == 'postgres' %}
    "sqlalchemy[asyncio]>=2.0.0",
    "asyncpg>=0.29.0",{% elif database == 'sqlite' %}
    "sqlalchemy[asyncio]>=2.0.0",
    "aiosqlite>=0.19.0",{% endif %}{% if use_alembic == 'true' %}
    "alembic>=1.13.0",{% endif %}
]

[project.optional-dependencies]
dev = [
    "pytest>=7.4.0",
    "pytest-asyncio>=0.23.0",
    "httpx>=0.26.0",
    "ruff>=0.1.0",
    "mypy>=1.8.0",
]

[tool.ruff]
target-version = "py{{ python_version | replace('.', '') }}"
line-length = 100

[tool.ruff.lint]
select = ["E", "F", "I", "UP"]

[tool.mypy]
python_version = "{{ python_version }}"
strict = true

[tool.pytest.ini_options]
asyncio_mode = "auto"
